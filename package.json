    "db:studio": "prisma studio",
    "db:seed": "node --env-file=.env scripts/seed-admin.mjs",
    "db:seed:demo": "node --env-file=.env scripts/seed-demo.mjs",
    "db:storage": "node --env-file=.env scripts/setup-storage.mjs",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^6.19.3",
