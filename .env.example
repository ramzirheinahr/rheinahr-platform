# ─────────────────────────────────────────────────────────────
# RheinAhr Staffing Platform — environment template
# Copy to `.env` (Prisma + Next.js both read it) and fill in.
# NEVER commit the filled-in file. All PII storage must stay EU-region.
# ─────────────────────────────────────────────────────────────

# ── Database (Supabase — EU region / Frankfurt) ──
# Pooled connection (app runtime). Use the Supabase "Connection pooling" URI.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (Prisma migrations). Supabase "Direct connection" URI.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ── Supabase Auth / Storage (EU region) ──
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"   # server-only, never expose

# ── App ──
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ── Email (Resend) ──
RESEND_API_KEY="re_xxxxxxxx"
EMAIL_FROM="RheinAhr Dienstleistungen <info@rheinahr-gmbh.de>"

# ── SMS / WhatsApp (Twilio — German number) · Phase 2 ──
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# ── Monitoring (Sentry — EU data residency) ──
SENTRY_DSN=""
