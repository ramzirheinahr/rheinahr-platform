// RheinAhr Dienstleistungen GmbH — Staffing Platform
// Prisma schema · derived from CLAUDE.md Section 5
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; the rhel target is what Vercel's serverless runtime uses.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────── Enums ───────────────────────────

enum Role {
  super_admin // owns account creation & role assignment
  admin // company staff / supervisors
  client // facility requesting staff
  worker // care professional providing the service
}

enum Language {
  de
  en
  ar
}

// Elderly-care (Altenpflege) qualifications only — see CLAUDE.md domain focus.
// pflegefachkraft covers all examinierten Fachkräfte (früher auch Altenpfleger/in
// und Gesundheits- & Krankenpfleger/in als eigene Werte — 2026-07 zusammengeführt).
enum Qualification {
  pflegefachkraft // examinierte Pflegefachkraft (Altenpflege)
  pflegehelfer // Pflegehilfskraft
  betreuungskraft // Betreuungskraft § 43b SGB XI
  pflegedienstleitung // Pflegedienstleitung (PDL)
}

enum ContractType {
  unbefristet // permanent
  befristet // fixed-term
  minijob
  werkstudent
}

enum AvailabilityStatus {
  available
  unavailable
  assigned
}

// Elderly-care facility types only.
enum FacilityType {
  pflegeheim // Pflegeheim
  seniorenheim // Senioren-/Altenheim
  ambulant // ambulanter Pflegedienst
  tagespflege // Tagespflege
  kurzzeitpflege // Kurzzeitpflege
}

enum OrderStatus {
  pending // 1. Request submitted
  review // 2. Admin review
  availability_check // 3. Availability check
  assigned // 4. Worker assignment
  accepted // 5. Worker acceptance
  in_progress // 7. Shift execution
  completed // shift done, awaiting confirmation
  confirmed // 8. Service confirmed
  cancelled
}

enum AssignmentStatus {
  pending
  confirmed
  declined
}

enum ConfirmationMethod {
  electronic // signature pad / click-to-confirm
  upload // signed scanned document
}

enum NotificationType {
  new_order
  worker_assigned
  worker_confirmed
  reminder_24h
  reminder_1h
  service_confirmed
  order_status_changed
  document_uploaded
  new_message
}

enum NotificationChannel {
  email
  sms
  in_app
}

enum OwnerType {
  worker
  client
}

enum DocumentCategory {
  certification // Approbation / Fachkunde
  id_document
  vaccination // Impfnachweis
  contract
  service_confirmation
  other
}

// ─────────────────────────── Models ───────────────────────────

model User {
  id                String   @id @default(uuid())
  email             String   @unique // login identity (Supabase Auth) — Google/Apple OAuth later
  fullName          String?  @map("full_name") // display name (esp. for staff/admins without a profile)
  passwordHash      String   @map("password_hash")
  role              Role
  active            Boolean  @default(true) // disabled accounts cannot sign in
  preferredLanguage Language @default(de) @map("preferred_language")
  twoFactorEnabled  Boolean  @default(false) @map("2fa_enabled")
  // Passwordless "access link + PIN" login (client/worker convenience). The admin
  // shares the /access/<loginToken> link; the user enters a 6-digit PIN once per
  // device, then the persistent session skips it. Never a full credential alone.
  loginToken        String?   @unique @map("login_token") // random slug in the shared link
  loginPinHash      String?   @map("login_pin_hash") // bcrypt of the 6-digit PIN
  loginPinAttempts  Int       @default(0) @map("login_pin_attempts") // brute-force counter
  loginPinLockUntil DateTime? @map("login_pin_lock_until") // temporary lockout after failures
  createdById       String?  @map("created_by") // which admin provisioned this account
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  worker               Worker?
  client               Client?
  notifications        Notification[]
  serviceConfirmations ServiceConfirmation[]
  sentMessages         Message[]
  conversations        ConversationParticipant[]
  createdConversations Conversation[]

  createdBy    User?  @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers User[] @relation("UserCreatedBy")

  @@map("users")
}

model Worker {
  id             String        @id @default(uuid())
  userId         String        @unique @map("user_id")
  fullName       String        @map("full_name")
  qualification  Qualification
  certifications String[]      @default([])
  contractType   ContractType  @map("contract_type")
  phone          String?
  address        String?
  // Languages spoken by the worker as ISO 639-1 codes (any world language).
  // Decoupled from the UI-locale enum (User.preferredLanguage stays de/en/ar).
  languages      String[]      @default([])
  // Personal / HR data (sensitive PII — admin-only, never exposed to clients).
  birthDate            DateTime? @map("birth_date") @db.Date
  birthPlace           String?   @map("birth_place")
  nationality          String?   // ISO 3166-1 alpha-2 country code
  socialSecurityNumber String?   @map("social_security_number") // Sozialversicherungsnummer
  // Professional profile (may be shown to clients).
  photoPath       String?  @map("photo_path") // Storage path in the worker-files bucket
  bio             String?  // Kurzprofil shown to clients
  skills          String[] @default([]) // specializations (Demenz, Palliativ, …)
  yearsExperience Int?     @map("years_experience")
  employedSince   DateTime? @map("employed_since") @db.Date
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  availability WorkerAvailability[]
  assignments  Assignment[]
  documents    WorkerDocument[]

  @@index([qualification])
  @@map("workers")
}

// Uploaded worker files (certificates, ID, vaccination proof …) stored in the
// private worker-files bucket; `filePath` is the storage key, served via a
// short-lived signed URL. `verified` is toggled by an admin after review.
model WorkerDocument {
  id         String           @id @default(uuid())
  workerId   String           @map("worker_id")
  category   DocumentCategory
  fileName   String           @map("file_name")
  filePath   String           @map("file_path")
  verified   Boolean          @default(false)
  uploadedAt DateTime         @default(now()) @map("uploaded_at")

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
  @@map("worker_documents")
}

// Unavailability blocks. A whole-day block has null start/end; otherwise the
// block covers [startTime, endTime]. Multiple blocks per day are allowed
// (e.g. unavailable for the early AND night shift).
model WorkerAvailability {
  id        String             @id @default(uuid())
  workerId  String             @map("worker_id")
  date      DateTime           @db.Date
  status    AvailabilityStatus @default(unavailable)
  startTime String?            @map("start_time") // null = whole day
  endTime   String?            @map("end_time")
  notes     String?

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId, date])
  @@index([date, status])
  @@map("worker_availability")
}

model Client {
  id            String       @id @default(uuid())
  userId        String       @unique @map("user_id")
  facilityName  String       @map("facility_name")
  // Dienstplan-Kürzel: the 2–3 letter facility code used on the master
  // schedule grid (e.g. "WB" = Limbachstift Wachtberg). Admin-assigned.
  shortCode     String?      @unique @map("short_code")
  facilityType  FacilityType @map("facility_type")
  address       String?
  contactPerson String?      @map("contact_person")
  billingInfo   String?      @map("billing_info")
  // Per-client billing surcharges (fractions, e.g. 0.25 = +25 %). Null falls
  // back to the platform default in lib/pricing.ts.
  surchargeSat     Float?    @map("surcharge_sat")
  surchargeSun     Float?    @map("surcharge_sun")
  surchargeHoliday Float?    @map("surcharge_holiday")
  // Per-client hourly rates (EUR netto) keyed by qualification, e.g.
  // { "pflegefachkraft": 54.9 }. Only overridden qualifications are stored;
  // missing keys fall back to HOURLY_RATES in lib/pricing.ts.
  hourlyRates      Json?     @map("hourly_rates")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("clients")
}

model Order {
  id                    String        @id @default(uuid())
  clientId              String        @map("client_id")
  requestGroupId        String?       @map("request_group_id") // groups shifts submitted together
  requiredQualification Qualification @map("required_qualification")
  shiftDate             DateTime      @map("shift_date") @db.Date
  startTime             String        @map("start_time") // "HH:mm"
  endTime               String        @map("end_time") // "HH:mm"
  quantity              Int           @default(1)
  status                OrderStatus   @default(pending)
  notes                 String?
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignments Assignment[]

  @@index([status])
  @@index([shiftDate])
  @@index([clientId, requestGroupId])
  @@map("orders")
}

model Assignment {
  id          String           @id @default(uuid())
  orderId     String           @map("order_id")
  workerId    String           @map("worker_id")
  status      AssignmentStatus @default(pending)
  assignedAt  DateTime         @default(now()) @map("assigned_at")
  confirmedAt DateTime?        @map("confirmed_at")

  order               Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  worker              Worker               @relation(fields: [workerId], references: [id], onDelete: Cascade)
  serviceConfirmation ServiceConfirmation?
  messages            Message[]
  conversation        Conversation?

  @@unique([orderId, workerId])
  @@index([workerId, status])
  @@map("assignments")
}

// Inbox thread. Agency staff (admin/super_admin) see every conversation; other
// users only those they participate in. Optional links tie a thread to its
// context: `assignmentId` for per-assignment chats (worker ↔ agency),
// `requestGroupId` for client change requests on an order request.
model Conversation {
  id             String   @id @default(uuid())
  subject        String? // free-text; context threads store e.g. "12.07.2026 · Facility"
  assignmentId   String?  @unique @map("assignment_id")
  requestGroupId String?  @map("request_group_id")
  createdById    String?  @map("created_by")
  lastMessageAt  DateTime @default(now()) @map("last_message_at")
  createdAt      DateTime @default(now()) @map("created_at")

  assignment   Assignment?               @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  createdBy    User?                     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  participants ConversationParticipant[]
  messages     Message[]

  @@index([lastMessageAt])
  @@index([requestGroupId])
  @@map("conversations")
}

// Membership + per-user read cursor. Agency staff get a row lazily (first
// read) purely to track `lastReadAt`; visibility for them never depends on it.
model ConversationParticipant {
  id             String    @id @default(uuid())
  conversationId String    @map("conversation_id")
  userId         String    @map("user_id")
  lastReadAt     DateTime? @map("last_read_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

// A single inbox message. `assignmentId` is a legacy column from the
// per-assignment-only messaging era (kept for existing rows); new messages
// always carry `conversationId`.
model Message {
  id             String   @id @default(uuid())
  conversationId String?  @map("conversation_id")
  assignmentId   String?  @map("assignment_id")
  senderId       String   @map("sender_id")
  body           String
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  assignment   Assignment?   @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  sender       User          @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([assignmentId, createdAt])
  @@map("messages")
}

model ServiceConfirmation {
  id            String             @id @default(uuid())
  assignmentId  String             @unique @map("assignment_id")
  confirmedById String?            @map("confirmed_by") // nullable so GDPR erasure keeps the financial record
  method        ConfirmationMethod
  signatureData String?            @map("signature_data") // base64 signature image
  documentUrl   String?            @map("document_url")
  hoursWorked   Decimal?           @map("hours_worked") @db.Decimal(5, 2)
  clientNotes   String?            @map("client_notes")
  confirmedAt   DateTime           @default(now()) @map("confirmed_at")
  ipAddress     String?            @map("ip_address")

  assignment  Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  confirmedBy User?       @relation(fields: [confirmedById], references: [id], onDelete: SetNull)

  @@map("service_confirmations")
}

model Notification {
  id        String              @id @default(uuid())
  userId    String              @map("user_id")
  type      NotificationType
  channel   NotificationChannel
  content   String
  sentAt    DateTime?           @map("sent_at")
  readAt    DateTime?           @map("read_at")
  createdAt DateTime            @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("notifications")
}

model Document {
  id         String           @id @default(uuid())
  ownerId    String           @map("owner_id")
  ownerType  OwnerType        @map("owner_type")
  category   DocumentCategory
  fileUrl    String           @map("file_url")
  verified   Boolean          @default(false)
  uploadedAt DateTime         @default(now()) @map("uploaded_at")

  @@index([ownerId, ownerType])
  @@map("documents")
}

// GDPR Art. 30 / access-log — every PII-touching data access event
model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id") // actor (null = system)
  action    String // e.g. "order.create", "confirmation.sign"
  entity    String? // affected entity name
  entityId  String?  @map("entity_id")
  ipAddress String?  @map("ip_address")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([entity, entityId])
  @@map("audit_logs")
}
