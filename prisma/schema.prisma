// RheinAhr Dienstleistungen GmbH — Staffing Platform
// Prisma schema · derived from CLAUDE.md Section 5
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; the rhel target is what Vercel's serverless runtime uses.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────── Enums ───────────────────────────

enum Role {
  super_admin // owns account creation & role assignment
  admin // company staff / supervisors
  client // facility requesting staff
  worker // care professional providing the service
}

enum Language {
  de
  en
  ar
}

// Elderly-care (Altenpflege) qualifications only — see CLAUDE.md domain focus.
// pflegefachkraft covers all examinierten Fachkräfte (früher auch Altenpfleger/in
// und Gesundheits- & Krankenpfleger/in als eigene Werte — 2026-07 zusammengeführt).
enum Qualification {
  pflegefachkraft // examinierte Pflegefachkraft (Altenpflege)
  pflegehelfer // Pflegehilfskraft
  betreuungskraft // Pflegefachassistent*in (frühere Bezeichnung: Betreuungskraft § 43b)
  pflegedienstleitung // Pflegedienstleitung (PDL)
}

enum ContractType {
  unbefristet // permanent
  befristet // fixed-term
  minijob
  werkstudent
}

enum AvailabilityStatus {
  available
  unavailable
  assigned
}

// Elderly-care facility types only.
enum FacilityType {
  pflegeheim // Pflegeheim
  seniorenheim // Senioren-/Altenheim
  ambulant // ambulanter Pflegedienst
  tagespflege // Tagespflege
  kurzzeitpflege // Kurzzeitpflege
}

enum OrderStatus {
  pending // 1. Request submitted
  review // 2. Admin review
  availability_check // 3. Availability check
  assigned // 4. Worker assignment
  accepted // 5. Worker acceptance
  in_progress // 7. Shift execution
  completed // shift done, awaiting confirmation
  confirmed // 8. Service confirmed
  cancelled
}

enum AssignmentStatus {
  pending
  confirmed
  declined
}

enum ContractStatus {
  pending
  signed
  cancelled
}

enum InvoiceStatus {
  unpaid
  paid
}

enum LeaveStatus {
  pending
  approved
  rejected
}

enum ConfirmationMethod {
  electronic // signature pad / click-to-confirm
  upload // signed scanned document
}

enum NotificationType {
  new_order
  worker_assigned
  worker_confirmed
  reminder_24h
  reminder_1h
  service_confirmed
  order_status_changed
  document_uploaded
  new_message
  contract_pending
  contract_signed
}

enum NotificationChannel {
  email
  sms
  in_app
}

enum OwnerType {
  worker
  client
}

enum DocumentCategory {
  certification // Approbation / Fachkunde
  id_document
  vaccination // Impfnachweis
  contract
  service_confirmation
  other
}

// ─────────────────────────── Models ───────────────────────────

model User {
  id                String    @id @default(uuid())
  email             String    @unique // login identity (Supabase Auth) — Google/Apple OAuth later
  fullName          String?   @map("full_name") // display name (esp. for staff/admins without a profile)
  passwordHash      String    @map("password_hash")
  role              Role
  active            Boolean   @default(true) // disabled accounts cannot sign in
  receiveEmails     Boolean   @default(true) @map("receive_emails")
  preferredLanguage Language  @default(de) @map("preferred_language")
  twoFactorEnabled  Boolean   @default(false) @map("2fa_enabled")
  // Passwordless "access link + PIN" login (client/worker convenience). The admin
  // shares the /access/<loginToken> link; the user enters a 6-digit PIN once per
  // device, then the persistent session skips it. Never a full credential alone.
  loginToken        String?   @unique @map("login_token") // random slug in the shared link
  loginPinHash      String?   @map("login_pin_hash") // bcrypt of the 6-digit PIN
  loginPinAttempts  Int       @default(0) @map("login_pin_attempts") // brute-force counter
  loginPinLockUntil DateTime? @map("login_pin_lock_until") // temporary lockout after failures
  createdById       String?   @map("created_by") // which admin provisioned this account
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  worker               Worker?
  client               Client?
  notifications        Notification[]
  serviceConfirmations ServiceConfirmation[]
  sentMessages         Message[]
  conversations        ConversationParticipant[]
  createdConversations Conversation[]
  pushSubscriptions    PushSubscription[]

  createdBy    User?  @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers User[] @relation("UserCreatedBy")

  @@map("users")
}

// A browser/device Web Push subscription for a user (one row per device). The
// endpoint is the push service URL; p256dh/auth are the client's encryption
// keys. Dead endpoints (404/410 on send) are pruned by the sender.
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model Worker {
  id                   String        @id @default(uuid())
  userId               String        @unique @map("user_id")
  internalNumber       String?       @map("internal_number")
  fullName             String        @map("full_name")
  qualification        Qualification
  certifications       String[]      @default([])
  contractType         ContractType  @map("contract_type")
  requiredHours        Float         @default(151.67) @map("required_hours")
  // Signed hours-account balance carried from earlier months/years (Arbeitszeit-
  // konto): positive = hours the worker still owes (deficit), negative = surplus
  // worked ahead (credit). Added to this month's required to get the total soll.
  carryoverHours       Float         @default(0) @map("carryover_hours")
  phone                String?
  address              String?
  // Languages spoken by the worker as ISO 639-1 codes (any world language).
  // Decoupled from the UI-locale enum (User.preferredLanguage stays de/en/ar).
  languages            String[]      @default([])
  // Personal / HR data (sensitive PII — admin-only, never exposed to clients).
  birthDate            DateTime?     @map("birth_date") @db.Date
  birthPlace           String?       @map("birth_place")
  nationality          String? // ISO 3166-1 alpha-2 country code
  socialSecurityNumber String?       @map("social_security_number") // Sozialversicherungsnummer
  // Professional profile (may be shown to clients).
  photoPath            String?       @map("photo_path") // Storage path in the worker-files bucket
  bio                  String? // Kurzprofil shown to clients
  skills               String[]      @default([]) // specializations (Demenz, Palliativ, …)
  yearsExperience      Int?          @map("years_experience")
  employedSince        DateTime?     @map("employed_since") @db.Date

  // Financial & Allowances
  travelAllowanceEnabled Boolean @default(false) @map("travel_allowance_enabled")
  travelAllowancePerKm   Float?  @map("travel_allowance_per_km")
  mealAllowanceEnabled   Boolean @default(false) @map("meal_allowance_enabled")
  mealAllowance          Float?  @default(14.0) @map("meal_allowance")

  // Custom Surcharges (Fractions, e.g. 0.25 = 25%)
  surchargeSat     Float?  @map("surcharge_sat")
  surchargeSun     Float?  @map("surcharge_sun")
  surchargeHoliday Float?  @map("surcharge_holiday")
  surchargeNight   Float?  @map("surcharge_night")
  nightStart       String? @map("night_start")
  nightEnd         String? @map("night_end")

  // Custom Hourly Rates (JSON map qualification -> rate)
  hourlyRates Json? @map("hourly_rates")

  // Employment Contract Data (Arbeitsvertrag)
  employmentStartDate    DateTime? @map("employment_start_date") @db.Date
  employmentEndDate      DateTime? @map("employment_end_date") @db.Date
  arbeitsvertragUrl      String?   @map("arbeitsvertrag_url")
  arbeitsvertragSignedAt DateTime? @map("arbeitsvertrag_signed_at")
  weeklyHours            Float?    @map("weekly_hours")
  monthlySalary          Float?    @map("monthly_salary")
  entgeltgruppe          String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  availability  WorkerAvailability[]
  assignments   Assignment[]
  documents     WorkerDocument[]
  leaveRequests LeaveRequest[]

  @@index([qualification])
  @@map("workers")
}

// Uploaded worker files (certificates, ID, vaccination proof …) stored in the
// private worker-files bucket; `filePath` is the storage key, served via a
// short-lived signed URL. `verified` is toggled by an admin after review.
model WorkerDocument {
  id         String           @id @default(uuid())
  workerId   String           @map("worker_id")
  category   DocumentCategory
  fileName   String           @map("file_name")
  filePath   String           @map("file_path")
  verified   Boolean          @default(false)
  uploadedAt DateTime         @default(now()) @map("uploaded_at")

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
  @@map("worker_documents")
}

// Unavailability blocks. A whole-day block has null start/end; otherwise the
// block covers [startTime, endTime]. Multiple blocks per day are allowed
// (e.g. unavailable for the early AND night shift).
model WorkerAvailability {
  id        String             @id @default(uuid())
  workerId  String             @map("worker_id")
  date      DateTime           @db.Date
  status    AvailabilityStatus @default(unavailable)
  startTime String?            @map("start_time") // null = whole day
  endTime   String?            @map("end_time")
  notes     String?

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId, date])
  @@index([date, status])
  @@map("worker_availability")
}

model Client {
  id                         String       @id @default(uuid())
  userId                     String       @unique @map("user_id")
  internalNumber             String?      @map("internal_number")
  facilityName               String       @map("facility_name")
  // Dienstplan-Kürzel: the 2–3 letter facility code used on the master
  // schedule grid (e.g. "WB" = Limbachstift Wachtberg). Admin-assigned.
  shortCode                  String?      @unique @map("short_code")
  facilityType               FacilityType @map("facility_type")
  address                    String?
  frameworkAgreementUrl      String?      @map("framework_agreement_url")
  frameworkAgreementSignedAt DateTime?    @map("framework_agreement_signed_at")
  contactPerson              String?      @map("contact_person")
  billingInfo                String?      @map("billing_info")
  // Per-client billing surcharges (fractions, e.g. 0.25 = +25 %). Null falls
  // back to the platform default in lib/pricing.ts.
  surchargeSat               Float?       @map("surcharge_sat")
  surchargeSun               Float?       @map("surcharge_sun")
  surchargeHoliday           Float?       @map("surcharge_holiday")
  // Night surcharge (fraction, default +25 %) applied to hours inside the night
  // window below. Null falls back to the platform default in lib/pricing.ts.
  surchargeNight             Float?       @map("surcharge_night")
  // Night window as HH:mm (overnight-aware, e.g. 20:00–06:00). Null = default.
  nightStart                 String?      @map("night_start")
  nightEnd                   String?      @map("night_end")
  // Per-client hourly rates (EUR netto) keyed by qualification, e.g.
  // { "pflegefachkraft": 54.9 }. Only overridden qualifications are stored;
  // missing keys fall back to HOURLY_RATES in lib/pricing.ts.
  hourlyRates                Json?        @map("hourly_rates")
  createdAt                  DateTime     @default(now()) @map("created_at")
  updatedAt                  DateTime     @updatedAt @map("updated_at")

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]
  contracts ClientContract[]
  invoices  Invoice[]

  @@map("clients")
}

model Order {
  id                    String        @id @default(uuid())
  clientId              String        @map("client_id")
  requestGroupId        String?       @map("request_group_id") // groups shifts submitted together
  requiredQualification Qualification @map("required_qualification")
  shiftDate             DateTime      @map("shift_date") @db.Date
  startTime             String        @map("start_time") // "HH:mm"
  endTime               String        @map("end_time") // "HH:mm"
  breakMinutes          Int           @default(30) @map("break_minutes") // unpaid break, subtracted from billable hours
  quantity              Int           @default(1)
  status                OrderStatus   @default(pending)
  notes                 String?
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignments Assignment[]

  @@index([status])
  @@index([shiftDate])
  @@index([clientId, requestGroupId])
  @@map("orders")
}

model Assignment {
  id                String           @id @default(uuid())
  orderId           String           @map("order_id")
  workerId          String           @map("worker_id")
  contractId        String?          @map("contract_id")
  invoiceId         String?          @map("invoice_id")
  status            AssignmentStatus @default(pending)
  assignedAt        DateTime         @default(now()) @map("assigned_at")
  confirmedAt       DateTime?        @map("confirmed_at")
  // Worker-initiated cancellation request: the worker asks the office to be
  // taken off this shift (with a note). Admin approves (→ assignment released,
  // order back to pending/grey) or rejects (→ flags cleared).
  cancelRequested   Boolean          @default(false) @map("cancel_requested")
  cancelNote        String?          @map("cancel_note")
  cancelRequestedAt DateTime?        @map("cancel_requested_at")
  // Exceptionally add meal allowance to this assignment even if the worker
  // does not globally receive meal allowances.
  addMealAllowance       Boolean          @default(false) @map("add_meal_allowance")
  excludeMealAllowance   Boolean          @default(false) @map("exclude_meal_allowance")
  excludeTravelAllowance Boolean          @default(false) @map("exclude_travel_allowance")
  // Bonus hours added exceptionally to this assignment (only paid to worker, not billed to client)
  bonusHours             Float            @default(0) @map("bonus_hours")

  order               Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  worker              Worker               @relation(fields: [workerId], references: [id], onDelete: Cascade)
  clientContract      ClientContract?      @relation(fields: [contractId], references: [id], onDelete: SetNull)
  invoice             Invoice?             @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  serviceConfirmation ServiceConfirmation?
  messages            Message[]
  conversation        Conversation?

  @@unique([orderId, workerId])
  @@index([workerId, status])
  @@map("assignments")
}

// Inbox thread. Agency staff (admin/super_admin) see every conversation; other
// users only those they participate in. Optional links tie a thread to its
// context: `assignmentId` for per-assignment chats (worker ↔ agency),
// `requestGroupId` for client change requests on an order request.
model Conversation {
  id             String   @id @default(uuid())
  subject        String? // free-text; context threads store e.g. "12.07.2026 · Facility"
  assignmentId   String?  @unique @map("assignment_id")
  requestGroupId String?  @map("request_group_id")
  leaveRequestId String?  @unique @map("leave_request_id")
  createdById    String?  @map("created_by")
  lastMessageAt  DateTime @default(now()) @map("last_message_at")
  createdAt      DateTime @default(now()) @map("created_at")

  assignment   Assignment?               @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  leaveRequest LeaveRequest?             @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
  createdBy    User?                     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  participants ConversationParticipant[]
  messages     Message[]

  @@index([lastMessageAt])
  @@index([requestGroupId])
  @@map("conversations")
}

model LeaveRequest {
  id        String      @id @default(uuid())
  workerId  String      @map("worker_id")
  status    LeaveStatus @default(pending)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  worker       Worker        @relation(fields: [workerId], references: [id], onDelete: Cascade)
  days         LeaveDay[]
  conversation Conversation?

  @@index([workerId, status])
  @@map("leave_requests")
}

model LeaveDay {
  id             String      @id @default(uuid())
  leaveRequestId String      @map("leave_request_id")
  date           DateTime    @db.Date
  hours          Float       @default(7.0)
  status         LeaveStatus @default(pending)

  leaveRequest LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)

  @@unique([leaveRequestId, date])
  @@index([date, status])
  @@map("leave_days")
}

// Membership + per-user read cursor. Agency staff get a row lazily (first
// read) purely to track `lastReadAt`; visibility for them never depends on it.
model ConversationParticipant {
  id             String    @id @default(uuid())
  conversationId String    @map("conversation_id")
  userId         String    @map("user_id")
  lastReadAt     DateTime? @map("last_read_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

// A single inbox message. `assignmentId` is a legacy column from the
// per-assignment-only messaging era (kept for existing rows); new messages
// always carry `conversationId`.
model Message {
  id             String   @id @default(uuid())
  conversationId String?  @map("conversation_id")
  assignmentId   String?  @map("assignment_id")
  senderId       String   @map("sender_id")
  body           String
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  assignment   Assignment?   @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  sender       User          @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([assignmentId, createdAt])
  @@map("messages")
}

model ClientContract {
  id            String         @id @default(uuid())
  clientId      String         @map("client_id")
  status        ContractStatus @default(pending)
  period        String?
  signatureData String?        @map("signature_data")
  documentUrl   String?        @map("document_url")
  signedAt      DateTime?      @map("signed_at")
  ipAddress     String?        @map("ip_address")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignments Assignment[]

  @@index([clientId, status])
  @@map("client_contracts")
}

model ServiceConfirmation {
  id                    String             @id @default(uuid())
  assignmentId          String             @unique @map("assignment_id")
  confirmedById         String?            @map("confirmed_by") // nullable so GDPR erasure keeps the financial record
  method                ConfirmationMethod
  signatureData         String?            @map("signature_data") // base64 signature image
  documentUrl           String?            @map("document_url")
  hoursWorked           Decimal?           @map("hours_worked") @db.Decimal(5, 2)
  clientNotes           String?            @map("client_notes")
  confirmedAt           DateTime           @default(now()) @map("confirmed_at")
  ipAddress             String?            @map("ip_address")
  // Admin-proposed hours correction on an ALREADY-signed record. While
  // `correctionHours` is set, the client is asked to re-confirm; on approval
  // `hoursWorked` is updated and these fields clear. The audit log keeps the
  // superseded value, so the change stays traceable.
  correctionHours       Decimal?           @map("correction_hours") @db.Decimal(5, 2)
  correctionNote        String?            @map("correction_note")
  correctionRequestedBy String?            @map("correction_requested_by")
  correctionRequestedAt DateTime?          @map("correction_requested_at")
  // Client-requested shift-window correction filed while confirming ("the shift
  // actually ran 07:00–15:30"). While set, the office reviews it from the inbox
  // thread; approving updates the order window + hours and clears the fields.
  requestedStart        String?            @map("requested_start")
  requestedEnd          String?            @map("requested_end")

  assignment  Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  confirmedBy User?      @relation(fields: [confirmedById], references: [id], onDelete: SetNull)

  @@map("service_confirmations")
}

model Notification {
  id        String              @id @default(uuid())
  userId    String              @map("user_id")
  type      NotificationType
  channel   NotificationChannel
  content   String
  // Portal-relative deep link (locale-agnostic, e.g. "/admin/orders/<id>" or
  // "/client/inbox/<conversationId>"). Null = no specific target to open.
  link      String?
  sentAt    DateTime?           @map("sent_at")
  readAt    DateTime?           @map("read_at")
  createdAt DateTime            @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("notifications")
}

model Document {
  id         String           @id @default(uuid())
  ownerId    String           @map("owner_id")
  ownerType  OwnerType        @map("owner_type")
  category   DocumentCategory
  fileUrl    String           @map("file_url")
  verified   Boolean          @default(false)
  uploadedAt DateTime         @default(now()) @map("uploaded_at")

  @@index([ownerId, ownerType])
  @@map("documents")
}

// GDPR Art. 30 / access-log — every PII-touching data access event
model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id") // actor (null = system)
  action    String // e.g. "order.create", "confirmation.sign"
  entity    String? // affected entity name
  entityId  String?  @map("entity_id")
  ipAddress String?  @map("ip_address")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([entity, entityId])
  @@map("audit_logs")
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique @map("invoice_number")
  clientId      String        @map("client_id")
  status        InvoiceStatus @default(unpaid)
  date          DateTime      @default(now())
  netAmount     Float         @map("net_amount")
  vatAmount     Float         @map("vat_amount")
  grossAmount   Float         @map("gross_amount")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignments Assignment[]

  @@index([clientId, status])
  @@map("invoices")
}
